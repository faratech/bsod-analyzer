{
  "name": "bsod-minidump-analyzer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "node server.js",
    "dev:frontend": "vite",
    "build": "vite build && node scripts/generate-sri.js",
    "build:no-sri": "vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production node server.js",
    "analyze-css": "node scripts/purge-css.js",
    "optimize-css": "node scripts/purge-css.js --apply"
  },
  "dependencies": {
    "@google/genai": "^1.51.0",
    "@upstash/redis": "^1.37.0",
    "compression": "^1.8.1",
    "concurrently": "^9.2.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "form-data": "^4.0.5",
    "jszip": "^3.10.1",
    "multer": "^2.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.2",
    "remark-gfm": "^4.0.1",
    "xxhash-wasm": "^1.1.0"
  },
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^8.0.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.13",
    "purgecss": "^8.0.0",
    "tailwindcss": "^4.2.4",
    "terser": "^5.46.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "overrides": {
    "picomatch": "^4"
  }
}
