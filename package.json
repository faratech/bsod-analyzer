{
  "name": "bsod-minidump-analyzer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "node server.js",
    "dev:frontend": "vite",
    "build": "vite build && node scripts/generate-sri.js",
    "build:no-sri": "vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production node server.js",
    "test": "node --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "check": "npm test && npm run typecheck && npm run build",
    "analyze-css": "node scripts/purge-css.js",
    "optimize-css": "node scripts/purge-css.js --apply"
  },
  "dependencies": {
    "@google/genai": "^2.9.0",
    "@upstash/redis": "^1.38.0",
    "compression": "^1.8.1",
    "concurrently": "^10.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jszip": "^3.10.1",
    "multer": "^2.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.0",
    "remark-gfm": "^4.0.1",
    "xxhash-wasm": "^1.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "purgecss": "^8.0.0",
    "tailwindcss": "^4.3.1",
    "terser": "^5.48.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "overrides": {
    "picomatch": "^4",
    "ip-address": "^10.2.0"
  }
}
