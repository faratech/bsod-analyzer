{
  "name": "bsod-minidump-analyzer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@11.17.0",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=11.0.0 <12.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "node server.js",
    "dev:frontend": "vite",
    "build": "vite build && vite build --ssr entry-server.tsx --outDir dist-ssr && node scripts/generate-sri.js && node scripts/prerender.mjs",
    "build:no-sri": "vite build",
    "build:ssr": "vite build --ssr entry-server.tsx --outDir dist-ssr",
    "prerender": "node scripts/prerender.mjs",
    "verify-hydration": "node scripts/verify-hydration.mjs",
    "preview": "vite preview",
    "start": "NODE_ENV=production node server.js",
    "test": "node --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "check": "npm test && npm run typecheck && npm run build",
    "analyze-css": "node scripts/purge-css.js",
    "optimize-css": "node scripts/purge-css.js --apply"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@google/genai": "^2.10.0",
    "@upstash/redis": "^1.38.0",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.9.0",
    "jszip": "^3.10.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "xxhash-wasm": "^1.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.16",
    "purgecss": "^8.0.0",
    "tailwindcss": "^4.3.1",
    "terser": "^5.48.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  },
  "overrides": {
    "picomatch": "^4",
    "ip-address": "^10.2.0"
  }
}
